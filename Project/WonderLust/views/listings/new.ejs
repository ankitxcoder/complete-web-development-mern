<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>New Listings Create Route </title>
</head>
<body>
    <!-- Code to Enter the  all filed data  -->
     <form method="POST" action="/listings">
       <input name="listing.[title]" placeholder="Enter Title" type="text" />
       <br>
       <textarea name="listing.[description]" placeholder="Enter Description" type="text"></textarea>
       <br>
       <input name="listing.[image]" placeholder="Enter Image URL here " type="text"/>
       <br>
       <input name="listing.[price]" placeholder="Enter the Price" type="number"/>
       <br>
       <input name="listing.[country]" placeholder="Enter Country Name" type="text" />
       <br>
       <input name="listing.[location]" placeholder="Enter you location" type="text" />
       <br>
       <button>Add</button>
     </form>

  
</body>
</html>


